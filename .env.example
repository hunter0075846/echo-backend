# ==========================================
# 数据库配置
# ==========================================
# 使用 Supabase 或 Neon 等免费 PostgreSQL 服务
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# ==========================================
# JWT 密钥配置
# ==========================================
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# ==========================================
# AI 服务配置
# ==========================================

# AI 提供商选择
# 可选值: openai | deepseek | qwen
# 切换提供商只需修改此配置，无需修改代码
AI_PROVIDER="openai"

# ------------------------------------------
# OpenAI 配置（当 AI_PROVIDER=openai 时使用）
# ------------------------------------------
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
# 可选模型: gpt-3.5-turbo, gpt-4, gpt-4-turbo, gpt-4o
OPENAI_MODEL="gpt-3.5-turbo"

# ------------------------------------------
# DeepSeek 配置（当 AI_PROVIDER=deepseek 时使用）
# ------------------------------------------
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
# 可选模型: deepseek-chat, deepseek-coder
DEEPSEEK_MODEL="deepseek-chat"

# ------------------------------------------
# 通义千问配置（当 AI_PROVIDER=qwen 时使用）
# ------------------------------------------
QWEN_API_KEY=""
QWEN_BASE_URL="https://dashscope.aliyuncs.com/api/v1"
# 可选模型: qwen-turbo, qwen-plus, qwen-max
QWEN_MODEL="qwen-turbo"

# ------------------------------------------
# 任务级别模型配置（可选，覆盖默认模型）
# 可以为不同任务指定不同模型
# ------------------------------------------
# AI_TASK_MODEL=""
# 例如：使用 GPT-4 处理复杂任务
# AI_TASK_MODEL="gpt-4"

# ==========================================
# 其他 AI 提供商（预留）
# ==========================================
ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-3-sonnet-20240229"

# ==========================================
# 应用配置
# ==========================================
NEXT_PUBLIC_APP_VERSION="1.0.0"
MIN_APP_VERSION="1.0.0"

# ==========================================
# 文件上传配置（可选）
# ==========================================
# 使用 Cloudinary 或 AWS S3 等
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
